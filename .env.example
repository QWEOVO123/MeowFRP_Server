FRP_CONTROL_HTTP_ADDR=:8080
# Command line -port=18080 overrides FRP_CONTROL_HTTP_ADDR.
FRP_CONTROL_CONFIG=frp-control-server.cfg.json
# MySQL DSN can be omitted on first start. The setup page will write it into cfg.
# FRP_CONTROL_MYSQL_DSN=root:root@tcp(127.0.0.1:3306)/frp_control?parseTime=true&multiStatements=true&charset=utf8mb4,utf8
# FRP_CONTROL_COOKIE_SECRET=change-me-to-a-long-random-secret
FRP_CONTROL_SESSION_TTL=12h
FRP_CONTROL_RUNTIME_TOKEN_TTL=1h
FRP_CONTROL_FRP_SERVER_ADDR=127.0.0.1
FRP_CONTROL_FRP_SERVER_PORT=7000
FRP_CONTROL_FRP_TRANSPORT_TLS=false
